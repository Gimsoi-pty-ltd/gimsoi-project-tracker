PORT=5001
NODE_ENV=development

# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="gs#secret"

# Prisma: console.prisma.io → your project → Connect → copy connection string.
DATABASE_URL=

# Gmail App Password (NOT your Gmail password):
# myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=

CLIENT_URL=http://localhost:5173

# Security Policies
CSRF_SECRET_KEY="replace_this_with_a_long_secure_random_string_in_production"

# Security Policies
CSRF_SECRET="replace_this_with_a_long_secure_random_string_in_production"

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_PROJECTS_API_BASE_URL=https://projectsapi.zoho.com/restapi
